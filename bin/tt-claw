#!/bin/bash
# tt-claw: Main CLI wrapper for OpenClaw integration with Tenstorrent

set -e

# Determine script and repo locations
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Export visible runtime directory
export OPENCLAW_STATE_DIR="$REPO_ROOT/openclaw-runtime"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Helper functions
error() {
    echo -e "${RED}❌ $1${NC}" >&2
}

success() {
    echo -e "${GREEN}✅ $1${NC}"
}

info() {
    echo -e "${BLUE}ℹ️  $1${NC}"
}

warn() {
    echo -e "${YELLOW}⚠️  $1${NC}"
}

# Show usage
usage() {
    cat << EOF
tt-claw: OpenClaw integration for Tenstorrent

Usage:
  tt-claw setup                 Auto-detect vLLM and generate configs
  tt-claw start [agent]         Start OpenClaw gateway
  tt-claw stop                  Stop OpenClaw gateway
  tt-claw restart               Restart OpenClaw gateway
  tt-claw status                Show gateway status
  tt-claw tui [agent]           Launch interactive TUI
  tt-claw explore               Show runtime directory structure
  tt-claw doctor                Verify configuration and safety
  tt-claw clean                 Remove runtime directory (reset)
  tt-claw help                  Show this help

Agents:
  expert                        Tenstorrent documentation expert (default)
  chip-quest                    Chip Quest adventure game
  terminal-dungeon              Terminal Dungeon adventure game
  conference-chaos              Conference Chaos adventure game

Examples:
  tt-claw setup                 # First-time setup
  tt-claw start                 # Start expert agent
  tt-claw start chip-quest      # Start game agent
  tt-claw tui                   # Interactive Q&A
  tt-claw explore               # See config structure

Environment:
  OPENCLAW_STATE_DIR=${OPENCLAW_STATE_DIR}
  Gateway Port: 18789 (OpenClaw default)

Runtime directory is VISIBLE at: ${OPENCLAW_STATE_DIR}
(Use 'tt-claw explore' to see what's inside)
EOF
}

# Check if OpenClaw is installed
check_openclaw_installed() {
    if ! command -v openclaw &> /dev/null && [ ! -f "$HOME/openclaw/openclaw.sh" ]; then
        error "OpenClaw not found"
        info "Install with: cd $REPO_ROOT/adventure-games/scripts && ./install-openclaw.sh"
        exit 1
    fi
}

# Get openclaw command
get_openclaw_cmd() {
    if command -v openclaw &> /dev/null; then
        echo "openclaw"
    elif [ -f "$HOME/openclaw/openclaw.sh" ]; then
        echo "$HOME/openclaw/openclaw.sh"
    else
        error "OpenClaw command not found"
        exit 1
    fi
}

# Check if gateway is running
is_gateway_running() {
    # Check if default port 18789 is being listened on by openclaw process
    if lsof -iTCP:18789 -sTCP:LISTEN >/dev/null 2>&1; then
        return 0
    fi
    # Fallback: check for any openclaw-gateway process
    pgrep -f "openclaw-gateway" >/dev/null 2>&1
}

# Command: setup
cmd_setup() {
    info "Setting up tt-claw with visible runtime directory..."

    # Run setup script
    if [ -f "$REPO_ROOT/lib/openclaw-setup.sh" ]; then
        "$REPO_ROOT/lib/openclaw-setup.sh"
    else
        # Fallback to existing setup scripts
        warn "Using existing setup scripts (not yet refactored)"
        cd "$REPO_ROOT/adventure-games/scripts"
        ./setup-game-agents.sh
    fi

    success "Setup complete!"
    info "Runtime directory: $OPENCLAW_STATE_DIR"
    echo
    echo "Next steps:"
    echo "  tt-claw start         # Start expert agent"
    echo "  tt-claw tui           # Interactive Q&A"
    echo "  tt-claw explore       # See what was created"
}

# Command: start
cmd_start() {
    local agent="${1:-expert}"

    check_openclaw_installed

    if is_gateway_running; then
        warn "Gateway already running on port 18789"
        return 0
    fi

    # Check if runtime directory exists
    if [ ! -d "$OPENCLAW_STATE_DIR" ]; then
        warn "Runtime directory not found. Running setup first..."
        cmd_setup
    fi

    info "Starting OpenClaw gateway (agent: $agent, port: 18789)..."
    info "Using runtime: $OPENCLAW_STATE_DIR"

    # Start gateway with custom state dir
    local openclaw_cmd=$(get_openclaw_cmd)

    # Start in background with explicit OPENCLAW_STATE_DIR
    # Using default port 18789 (OpenClaw default) for TUI compatibility
    nohup env OPENCLAW_STATE_DIR="$OPENCLAW_STATE_DIR" "$openclaw_cmd" gateway run \
        > "$OPENCLAW_STATE_DIR/gateway.log" 2>&1 &

    local pid=$!

    # Wait a moment to check if it started
    sleep 2

    if is_gateway_running; then
        success "Gateway started (PID: $pid)"
        info "Logs: $OPENCLAW_STATE_DIR/gateway.log"
        info "Use 'tt-claw tui' to interact"
    else
        error "Gateway failed to start"
        info "Check logs: tail -f $OPENCLAW_STATE_DIR/gateway.log"
        exit 1
    fi
}

# Command: stop
cmd_stop() {
    if ! is_gateway_running; then
        info "Gateway not running"
        return 0
    fi

    info "Stopping OpenClaw gateway..."
    pkill -f "openclaw-gateway"

    sleep 1

    if ! is_gateway_running; then
        success "Gateway stopped"
    else
        error "Failed to stop gateway"
        exit 1
    fi
}

# Command: restart
cmd_restart() {
    cmd_stop
    sleep 1
    cmd_start "$@"
}

# Command: status
cmd_status() {
    echo "tt-claw Status:"
    echo "  Runtime: $OPENCLAW_STATE_DIR"
    echo "  Port: 18789 (OpenClaw default)"
    echo

    if is_gateway_running; then
        success "Gateway: Running"
        local pid=$(pgrep -f "openclaw-gateway" | head -1)
        if [ -n "$pid" ]; then
            info "  PID: $pid"
        fi
        info "  Logs: $OPENCLAW_STATE_DIR/gateway.log"
    else
        warn "Gateway: Not running"
    fi

    echo

    # Check vLLM
    if curl -s http://localhost:8000/v1/models >/dev/null 2>&1; then
        success "vLLM: Running on port 8000"
    elif curl -s http://localhost:8001/v1/models >/dev/null 2>&1; then
        success "vLLM Proxy: Running on port 8001"
    else
        warn "vLLM: Not detected on ports 8000 or 8001"
    fi

    echo

    # Check runtime directory
    if [ -d "$OPENCLAW_STATE_DIR" ]; then
        success "Runtime directory exists"
        local config_file="$OPENCLAW_STATE_DIR/openclaw.json"
        if [ -f "$config_file" ]; then
            success "Configuration found"
        else
            warn "Configuration not found (run 'tt-claw setup')"
        fi
    else
        warn "Runtime directory not found (run 'tt-claw setup')"
    fi
}

# Command: tui
cmd_tui() {
    local agent="${1:-expert}"

    check_openclaw_installed

    if ! is_gateway_running; then
        warn "Gateway not running. Starting it first..."
        cmd_start "$agent"
    fi

    info "Launching TUI (agent: $agent)..."
    info "Connecting to: $OPENCLAW_STATE_DIR"

    local openclaw_cmd=$(get_openclaw_cmd)
    # Explicitly set OPENCLAW_STATE_DIR for the TUI process
    OPENCLAW_STATE_DIR="$OPENCLAW_STATE_DIR" "$openclaw_cmd" tui
}

# Command: explore
cmd_explore() {
    info "Runtime directory structure:"
    echo

    if [ -d "$OPENCLAW_STATE_DIR" ]; then
        if command -v tree >/dev/null 2>&1; then
            tree -L 3 -a "$OPENCLAW_STATE_DIR"
        else
            find "$OPENCLAW_STATE_DIR" -maxdepth 3 -print | sed 's|[^/]*/| |g'
        fi

        echo
        info "Total size: $(du -sh "$OPENCLAW_STATE_DIR" | cut -f1)"

        # Show key files
        echo
        echo "Key files:"
        [ -f "$OPENCLAW_STATE_DIR/openclaw.json" ] && echo "  ✓ openclaw.json (main config)"
        [ -d "$OPENCLAW_STATE_DIR/agents" ] && echo "  ✓ agents/ (agent configs)"
        [ -d "$OPENCLAW_STATE_DIR/workspace" ] && echo "  ✓ workspace/ (agent workspace)"
        [ -d "$OPENCLAW_STATE_DIR/memory" ] && echo "  ✓ memory/ (vector database)"
        [ -f "$OPENCLAW_STATE_DIR/gateway.log" ] && echo "  ✓ gateway.log (latest logs)"
    else
        warn "Runtime directory not found: $OPENCLAW_STATE_DIR"
        info "Run 'tt-claw setup' to create it"
    fi
}

# Command: doctor
cmd_doctor() {
    info "Running safety and configuration checks..."
    echo

    if [ -f "$REPO_ROOT/lib/safety-check.sh" ]; then
        "$REPO_ROOT/lib/safety-check.sh"
    else
        warn "Safety check script not found (not yet implemented)"

        # Basic checks
        if [ -f "$OPENCLAW_STATE_DIR/openclaw.json" ]; then
            echo "Checking for remote providers..."
            if grep -q "127.0.0.1\|localhost" "$OPENCLAW_STATE_DIR/openclaw.json"; then
                success "Only localhost providers found"
            else
                error "Possible remote provider detected!"
                warn "Review: $OPENCLAW_STATE_DIR/openclaw.json"
            fi
        fi
    fi
}

# Command: clean
cmd_clean() {
    warn "This will delete the entire runtime directory:"
    warn "  $OPENCLAW_STATE_DIR"
    echo
    read -p "Are you sure? (y/N): " -n 1 -r
    echo

    if [[ $REPLY =~ ^[Yy]$ ]]; then
        if [ -d "$OPENCLAW_STATE_DIR" ]; then
            rm -rf "$OPENCLAW_STATE_DIR"
            success "Runtime directory removed"
            info "Run 'tt-claw setup' to recreate"
        else
            info "Runtime directory doesn't exist"
        fi
    else
        info "Cancelled"
    fi
}

# Main command dispatcher
main() {
    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        setup)
            cmd_setup "$@"
            ;;
        start)
            cmd_start "$@"
            ;;
        stop)
            cmd_stop "$@"
            ;;
        restart)
            cmd_restart "$@"
            ;;
        status)
            cmd_status "$@"
            ;;
        tui)
            cmd_tui "$@"
            ;;
        explore)
            cmd_explore "$@"
            ;;
        doctor)
            cmd_doctor "$@"
            ;;
        clean)
            cmd_clean "$@"
            ;;
        help|--help|-h)
            usage
            ;;
        *)
            error "Unknown command: $cmd"
            echo
            usage
            exit 1
            ;;
    esac
}

main "$@"
