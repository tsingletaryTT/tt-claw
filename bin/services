#!/bin/bash
# Start OpenClaw services with portable config from ~/tt-claw/

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RUNTIME_DIR="$SCRIPT_DIR/runtime"

echo "=== Starting OpenClaw Services (Portable Setup) ==="
echo "Runtime: $RUNTIME_DIR"
echo ""

# Source detection library
source "$SCRIPT_DIR/lib/vllm-detect.sh"

# Check vLLM is running and detect model (shared service)
echo "Detecting vLLM endpoint..."
if ! detect_vllm_endpoint > /dev/null 2>&1; then
  echo "✗ vLLM not responding - start it first!"
  echo "  Docker: cd ~/code/tt-inference-server && python3 run.py --model <model> --workflow server --docker-server --no-auth"
  echo "  Direct: See ~/tt-claw/docs/VLLM_DIRECT_70B_SOLUTION.md"
  exit 1
fi

# Get available models
DETECTED_MODELS=$(get_vllm_models)
if [ -z "$DETECTED_MODELS" ]; then
  echo "✗ vLLM is running but no models found!"
  exit 1
fi

# Pick best model
DETECTED_MODEL=$(pick_best_model "$DETECTED_MODELS")
DETECTED_CONTEXT=$(get_context_window "$DETECTED_MODEL")

echo "✓ vLLM is running on port $VLLM_PORT"
echo "  Model: $DETECTED_MODEL"
echo "  Context: $DETECTED_CONTEXT tokens"

# Update OpenClaw config with detected model
echo ""
echo "Updating OpenClaw config with detected model..."
CONFIG_FILE="$RUNTIME_DIR/openclaw.json"
BACKUP_FILE="$RUNTIME_DIR/openclaw.json.backup"

if [ -f "$CONFIG_FILE" ]; then
  # Backup config
  cp "$CONFIG_FILE" "$BACKUP_FILE"

  # Update model in config using jq
  jq --arg model "$DETECTED_MODEL" \
     --arg context "$DETECTED_CONTEXT" \
     --arg model_ref "vllm/$DETECTED_MODEL" \
     '.models.providers.vllm.models[0].id = $model |
      .models.providers.vllm.models[0].contextWindow = ($context | tonumber) |
      .agents.defaults.model.primary = $model_ref' \
     "$CONFIG_FILE" > "$CONFIG_FILE.tmp" && mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"

  echo "✓ Config updated: $CONFIG_FILE"
  echo "  Backup saved: $BACKUP_FILE"
else
  echo "⚠ Config not found: $CONFIG_FILE"
fi

# Stop existing services
echo ""
echo "Stopping existing services..."
pkill -f "openclaw.*gateway" 2>/dev/null || true
pkill -f "vllm-proxy" 2>/dev/null || true
sleep 2

# Start proxy
echo ""
echo "Starting vLLM proxy (port 8001)..."
cd "$SCRIPT_DIR/proxy"
python3 vllm-proxy.py > "$RUNTIME_DIR/logs/proxy.log" 2>&1 &
PROXY_PID=$!
sleep 2

# Check proxy
if curl -s --max-time 2 http://localhost:8001/v1/models 2>/dev/null | grep -q '"id"'; then
  echo "✓ Proxy is running (PID: $PROXY_PID)"
else
  echo "⚠ Proxy may not be responding (check $RUNTIME_DIR/logs/proxy.log)"
fi

# Start gateway with portable config
echo ""
echo "Starting OpenClaw gateway (port 18789)..."
export OPENCLAW_STATE_DIR="$RUNTIME_DIR"
export OPENCLAW_CONFIG_PATH="$RUNTIME_DIR/openclaw.json"

cd ~/openclaw
./openclaw.sh gateway run > "$RUNTIME_DIR/logs/gateway.log" 2>&1 &
GATEWAY_PID=$!
sleep 5

# Check gateway
if ps -p $GATEWAY_PID > /dev/null 2>&1; then
  echo "✓ Gateway is running (PID: $GATEWAY_PID)"
else
  echo "✗ Gateway failed to start (check $RUNTIME_DIR/logs/gateway.log)"
  exit 1
fi

echo ""
echo "=== Services Started Successfully ==="
echo "Proxy log:   $RUNTIME_DIR/logs/proxy.log"
echo "Gateway log: $RUNTIME_DIR/logs/gateway.log"
echo ""
echo "Use OpenClaw:"
echo "  $SCRIPT_DIR/bin/openclaw status"
echo "  $SCRIPT_DIR/bin/openclaw tui"
echo ""
echo "Play adventure games:"
echo "  $SCRIPT_DIR/bin/adventure-menu"
