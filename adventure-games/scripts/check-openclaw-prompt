#!/bin/bash
# Check OpenClaw System Prompt Version

PROMPT_FILE="/home/ttclaw/.openclaw/agents/main/agent/system.md"

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "OpenClaw System Prompt Checker"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# Check if file exists (need sudo to read ttclaw's files)
if ! sudo test -f "$PROMPT_FILE"; then
    echo "❌ System prompt file not found: $PROMPT_FILE"
    exit 1
fi

echo "📁 Location: $PROMPT_FILE"
FILESIZE=$(sudo stat -c %s "$PROMPT_FILE" 2>/dev/null)
FILEDATE=$(sudo stat -c %y "$PROMPT_FILE" 2>/dev/null | cut -d. -f1)
echo "📊 Size: $FILESIZE bytes"
echo "📅 Modified: $FILEDATE"
echo ""

# Check version markers
echo "🔍 Version Detection:"
echo ""

if sudo grep -q "You are a human expert who happens to have perfect memory" "$PROMPT_FILE"; then
    echo "✅ Ultra-direct v3 prompt detected"
    echo "   - Has 'Absolute Rules' section"
    echo "   - Has 'Mental Model' framing"
    echo "   - Behavioral imperatives (not just examples)"

    if sudo grep -q "NEVER EVER do these things" "$PROMPT_FILE"; then
        echo "   - Has strengthened 'NEVER EVER' commands ✅"
    fi

    echo ""
    echo "🎯 Expected Behavior:"
    echo "   Agent answers as an expert with perfect memory,"
    echo "   NOT narrating process or suggesting tool calls"
    echo ""
    echo "⚠️  Note: If agent still narrates with 8B model,"
    echo "   consider upgrading to Llama-3.3-70B-Instruct"

elif sudo grep -q "CRITICAL: What NOT to Do" "$PROMPT_FILE"; then
    echo "⚠️  Enhanced v2 prompt detected (may not be enough)"
    echo "   - Has 'CRITICAL: What NOT to Do' section"
    echo "   - Explicitly prevents tool narration"

    if sudo grep -q "NEVER say.*memory_get function has returned" "$PROMPT_FILE"; then
        echo "   - Has specific 'memory_get' anti-pattern examples ✅"
    fi

    if sudo grep -q "NEVER narrate.*your tool usage" "$PROMPT_FILE"; then
        echo "   - Has 'never narrate tool usage' instruction ✅"
    fi

    echo ""
    echo "🎯 Expected Behavior:"
    echo "   Agent should answer directly using memory content,"
    echo "   NOT say 'The memory_get function has returned...'"
    echo ""
    echo "💡 Upgrade to v3 with:"
    echo "   sudo cp /tmp/openclaw-system-prompt-v3.md $PROMPT_FILE"

elif sudo grep -q "Don't just say.*I found this" "$PROMPT_FILE"; then
    echo "⚠️  Original v1 prompt detected"
    echo "   - Has basic examples but no explicit anti-patterns"
    echo "   - May still narrate tool usage"
    echo ""
    echo "💡 Upgrade to v3 with:"
    echo "   sudo cp /tmp/openclaw-system-prompt-v3.md $PROMPT_FILE"
else
    echo "❓ Unknown prompt version"
    echo "   - Doesn't match v1, v2, or v3 signatures"
fi

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# Offer to show content
if [ "$1" == "--show" ] || [ "$1" == "-s" ]; then
    echo "📄 Full System Prompt:"
    echo ""
    sudo cat "$PROMPT_FILE"
    echo ""
else
    echo "💡 To see full prompt: $(basename "$0") --show"
fi

# Check if gateway needs restart
if ps aux | grep "openclaw-gateway" | grep -v grep > /dev/null 2>&1; then
    GATEWAY_PID=$(pgrep -f openclaw-gateway 2>/dev/null | head -1)
    echo "✅ Gateway is running (PID: $GATEWAY_PID)"
    echo ""
    echo "⚠️  Remember: New prompt only applies to FRESH TUI sessions"
    echo "   1. Exit current TUI (Ctrl+C)"
    echo "   2. Start fresh: sudo -u ttclaw /home/ttclaw/openclaw/openclaw.sh tui"
else
    echo "⚠️  Gateway is NOT running"
    echo "   Start with: sudo -u ttclaw /home/ttclaw/openclaw/openclaw.sh gateway run &"
fi

echo ""
